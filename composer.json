{
  "name": "bwtech/files_primary_s3",
  "description": "S3 primary storage integration for owncloud.online (PHP 8.4 fork of owncloud/files_external_s3)",
  "require": {
    "php": ">=8.4",
    "aws/aws-sdk-php": "^3.337",
    "guzzlehttp/guzzle": "^7.7",
    "guzzlehttp/psr7": "^2.5"
  },
  "license": "GPL-2.0-only",
  "config": {
    "optimize-autoloader": true,
    "classmap-authoritative": false,
    "platform": {
      "php": "8.4"
    },
    "allow-plugins": {
      "bamarni/composer-bin-plugin": true
    }
  },
  "require-dev": {
    "bamarni/composer-bin-plugin": "^1.8",
    "roave/security-advisories": "dev-latest"
  },
  "extra": {
    "bamarni-bin": {
      "bin-links": false
    }
  }
}
